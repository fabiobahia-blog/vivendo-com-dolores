#
# Pooler (migrations CLI): aws-1-sa-east-1.pooler.supabase.com:5432
# User: postgres.gduyitvnnyuewwbebeyq

# Senha do banco (só uso local/admin — NUNCA commitar)
SUPABASE_DB_PASSWORD=

# URL da Data API (REST)

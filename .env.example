# Copie este arquivo para .env e preencha os valores:
#   cp .env.example .env
#
# Preferência: use GITHUB_TOKEN (Personal Access Token) em vez de senha.
# Crie em: https://github.com/settings/tokens

GITHUB_EMAIL=seu-email@exemplo.com
GITHUB_USERNAME=seu-usuario-github

# Token de acesso pessoal (recomendado para git push)
GITHUB_TOKEN=

# Senha da conta (evite se possível; GitHub pode bloquear login por senha no git)
GITHUB_PASSWORD=

# Nome do repositório no GitHub (sem o usuário)
GITHUB_REPO=meu-blog

# Google Analytics 4 (Measurement ID, ex: G-ABC123XYZ)
GA_MEASUREMENT_ID=G-XXXXXXXXXX

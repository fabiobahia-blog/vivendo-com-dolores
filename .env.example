# Copie este arquivo para .env e preencha os valores:
#   cp .env.example .env

# --- GitHub ---
GITHUB_EMAIL=seu-email@exemplo.com
GITHUB_USERNAME=seu-usuario-github
GITHUB_TOKEN=
GITHUB_PASSWORD=
GITHUB_REPO=vivendo-com-dolores

# --- Cloudflare Web Analytics ---
CF_ANALYTICS_TOKEN=COLE_SEU_TOKEN_AQUI
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# --- Supabase (Mural de Recados / Guestbook) ---

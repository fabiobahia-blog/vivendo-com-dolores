# Copie este arquivo para .env e preencha os valores:
#   cp .env.example .env

# --- GitHub ---
GITHUB_EMAIL=seu-email@exemplo.com
GITHUB_USERNAME=seu-usuario-github
GITHUB_TOKEN=
GITHUB_PASSWORD=
GITHUB_REPO=vivendo-com-dolores

# --- Cloudflare Web Analytics ---
CF_ANALYTICS_TOKEN=COLE_SEU_TOKEN_AQUI
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# --- Supabase (Mural de Recados) ---
# Senha do banco (só uso local/admin — NUNCA commitar)
SUPABASE_DB_PASSWORD=

# URL da Data API (REST)
SUPABASE_API_URL=https://gduyitvnnyuewwbebeyq.supabase.co/rest/v1/

# URL base do projeto (usada pelo cliente JS no navegador)
SUPABASE_PROJECT_URL=https://gduyitvnnyuewwbebeyq.supabase.co

# Chave pública: Settings → API Keys → Publishable key (sb_publishable_...)
MURAL_SUPABASE_URL=https://gduyitvnnyuewwbebeyq.supabase.co
MURAL_SUPABASE_ANON_KEY=
